# Copy this to .env and fill in your values.
# .env is gitignored — never commit real keys.

# Required for real Claude-generated narratives.
# Leave blank or unset to use the mock LLM fallback (templated narratives).
ANTHROPIC_API_KEY=

# Set to "true" to skip the Anthropic API call entirely, even if a key is set.
# Useful for offline development and CI.
USE_MOCK_LLM=false

# CORS — comma-separated origins, or "*" for any.
# Tighten this in production.
CORS_ORIGINS=*

# Database URL — only override if you're running outside docker compose.
# DATABASE_URL=postgresql+asyncpg://divergence:divergence@localhost:5433/divergence

# Scoring cadence in minutes (default 15).
# SCORING_INTERVAL_MINUTES=15

# Z-score threshold for triggering an alert (default 2.0).
# ALERT_THRESHOLD_Z=2.0

# LLM model + temperature for narratives.
# LLM_MODEL=claude-sonnet-4-5
# LLM_TEMPERATURE=0.3
# PROMPT_VERSION=v3-2026-05
